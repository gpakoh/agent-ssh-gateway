# Web SSH Gateway — Nginx configuration example
# Replace gateway.example.com and 10.0.0.10 with your actual domain and backend IP.
# Real deploy configs: keep in private repo or Gitea, not in public GitHub.

# HTTP → HTTPS redirect
server {
    listen 80;
    server_name gateway.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name gateway.example.com;

    # SSL certificates (managed by certbot / ACME)
    ssl_certificate     /etc/letsencrypt/live/gateway.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gateway.example.com/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ---- mTLS for agent certificates ----
    ssl_client_certificate /etc/nginx/certs/ca.crt;
    ssl_verify_client       optional;
    ssl_verify_depth        2;

    proxy_set_header X-SSL-Client-Verify $ssl_client_verify;
    proxy_set_header X-SSL-Client-DN     $ssl_client_s_dn;
    proxy_set_header X-SSL-Client-Serial $ssl_client_serial;

    # Optional: SSO / Authelia auth
    # include /etc/nginx/snippets/authelia-location.conf;

    # Health endpoint — no auth
    location /health {
        access_log off;
        add_header Content-Type application/json;
        return 200 '{"status":"ok"}';
    }

    # Default location — mTLS bypass, otherwise SSO auth
    location / {
        proxy_pass http://10.0.0.10:8085;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-API-Key "__API_KEY__";

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $http_connection;
    }

    # WebSocket execute stream
    location /api/ssh/execute/stream {
        proxy_pass http://10.0.0.10:8085;
        proxy_set_header X-API-Key "__API_KEY__";
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_buffering off;
        proxy_read_timeout 86400s;
    }

    # WebSocket PTY
    location /api/ssh/pty/ {
        proxy_pass http://10.0.0.10:8085;
        proxy_set_header X-API-Key "__API_KEY__";
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_buffering off;
        proxy_read_timeout 86400s;
    }

    # SSO auth fallback
    location /_mtls-auth/ {
        internal;
        # auth_request /authelia;
        rewrite ^/_mtls-auth/(.*)$ /$1 break;
        proxy_pass http://10.0.0.10:8085;
        proxy_set_header X-API-Key "__API_KEY__";
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
