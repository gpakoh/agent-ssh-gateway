+# ---------------------------------------------------------------------------
+# execute_argv — shell redirect metachar denial
+# ---------------------------------------------------------------------------
+
+
+class TestExecuteArgvRedirectMetachar:
+    """execute_argv with shell redirect metachars must be denied even in enforce-readonly."""
+
+    def test_redirect_gt_denied(self, client, monkeypatch):
+        """argv=['sh','-c','echo x > f'] → joined command contains '>' → FORBIDDEN."""
+        _setup_test(monkeypatch)
+        _setup_enforce_readonly(monkeypatch)
+
+        resp = client.post(
+            "/api/ssh/execute-argv",
+            json={"session_id": "sid", "argv": ["sh", "-c", "echo x > f"]},
+            headers=_auth_headers(),
+        )
+        assert resp.status_code == 403
+        assert resp.json()["detail"]["code"] == "FORBIDDEN"
+
+    def test_redirect_appended_denied(self, client, monkeypatch):
+        """argv=['sh','-c','echo x >> f'] → FORBIDDEN."""
+        _setup_test(monkeypatch)
+        _setup_enforce_readonly(monkeypatch)
+
+        resp = client.post(
+            "/api/ssh/execute-argv",
+            json={"session_id": "sid", "argv": ["sh", "-c", "echo x >> /tmp/f"]},
+            headers=_auth_headers(),
+        )
+        assert resp.status_code == 403
+
+    def test_pipe_denied(self, client, monkeypatch):
+        """argv=['sh','-c','echo x | cat'] → FORBIDDEN."""
+        _setup_test(monkeypatch)
+        _setup_enforce_readonly(monkeypatch)
+
+        resp = client.post(
+            "/api/ssh/execute-argv",
+            json={"session_id": "sid", "argv": ["sh", "-c", "echo x | cat"]},
+            headers=_auth_headers(),
+        )
+        assert resp.status_code == 403
+
+
+# ---------------------------------------------------------------------------
+# ExecuteRequest profile forwarding
+# ---------------------------------------------------------------------------
+
+
+class TestExecuteProfileForwarding:
+    """POST /api/ssh/execute with profile= must use that profile for policy check."""
+
+    def test_profile_overrides_global(self, client, monkeypatch):
+        """Global readonly, request with profile=testlint → testlint policy applies."""
+        _setup_test(monkeypatch)
+        monkeypatch.setattr(settings, "command_policy_mode", "enforce")
+        monkeypatch.setattr(settings, "command_policy_profile", "readonly")
+
+        mock_session = MagicMock()
+        mock_session.owner_type = "master"
+        mock_session.owner_token_fingerprint = None
+        _app_state = _setup_test(monkeypatch)
+        _app_state.manager.get_session = AsyncMock(return_value=mock_session)
+        _app_state.manager.execute = AsyncMock(
+            return_value={"stdout": "ok", "stderr": "", "exit_code": 0, "duration": 0.1}
+        )
+
+        # readonly allows 'ls -la', testlint also allows 'ls -la'
+        resp = client.post(
+            "/api/ssh/execute",
+            json={
+                "session_id": "sid",
+                "command": "ls -la",
+                "profile": "testlint",
+            },
+            headers=_auth_headers(),
+        )
+        # Should not be 403 for either profile — both allow 'ls'
+        assert resp.status_code == 200
+
+
+# ---------------------------------------------------------------------------
+# MCP client — no duplicate policy drift
+# ---------------------------------------------------------------------------
+
+
+class TestMcpNoDuplicatePolicy:
+    """gateway_client.execute_restricted must NOT call validate_readonly_command locally."""
+
+    def test_execute_restricted_no_local_policy_call(self):
+        """After C3, validate_readonly_command is not imported in gateway_client."""
+
+        # Re-import gateway_client module to check its source
+        from examples.mcp_server import gateway_client
+
+        # The module should not reference validate_readonly_command
+        # (it may still exist in command_policy.py, but not used by gateway_client)
+        source = inspect.getsource(gateway_client)
+        assert "validate_readonly_command" not in source, (
+            "gateway_client still references validate_readonly_command — "
+            "MCP-local duplicate policy must be removed"
+        )
+
