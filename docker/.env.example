# Docker Compose runtime environment — copy this file to .env and fill real values.
# Do not commit .env with real secrets.

API_KEY=change-me-generate-long-random-api-key
AGENT_TOKEN=change-me-generate-long-random-agent-token
AGENT_TOKEN_TTL=31536000
JWT_SECRET=change-me-generate-long-random-jwt-secret

# PostgreSQL superuser password (mcp-postgres container)
POSTGRES_PASSWORD=change-me

# Fernet key for encrypting session credentials at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-fernet-key

# Access control gate (Phase 12B)
ACCESS_CONTROL_ENABLED=true
ACCESS_CONTROL_ENFORCE_MASTER=false
ACCESS_CONTROL_PENDING_TTL=900
ACCESS_CONTROL_ALLOW_TTL=86400
ACCESS_CONTROL_DENY_TTL=86400
# ACCESS_CONTROL_REDIS_URL=redis://redis:6379/0
