# ChatGPT remote MCP adapter

GATEWAY_BASE_URL=http://127.0.0.1:8085
GATEWAY_API_KEY=
GATEWAY_SESSION_ID=

# SSH connection for auto-reconnect on SESSION_NOT_FOUND
# Required if GATEWAY_SESSION_ID may expire (gateway/redis/sshd restart).
# When SESSION_NOT_FOUND is detected, the client creates a new session
# using these parameters and retries the operation once.
GATEWAY_SSH_HOST=
GATEWAY_SSH_PORT=22
# GATEWAY_SSH_USER or GATEWAY_SSH_USERNAME (both supported for compatibility)
GATEWAY_SSH_USER=
GATEWAY_SSH_USERNAME=
GATEWAY_SSH_PASSWORD=
# GATEWAY_SSH_PRIVATE_KEY= (inline, but for multi-line keys use GATEWAY_SSH_KEY_PATH)
# GATEWAY_SSH_KEY_PATH=/path/to/private_key (alternative to inline PRIVATE_KEY)

# Auth mode:
#   oauth — Bearer token only (default). mcp_token query param rejected.
#   token — legacy ?mcp_token= query param (rollback only).
MCP_AUTH_MODE=oauth

# Legacy token used in ?mcp_token= query param (only for token mode).
MCP_PUBLIC_TOKEN=

MCP_HOST=127.0.0.1
MCP_PORT=8788

# Tool visibility: minimal, standard, full, chatgpt (recommended for ChatGPT)
MCP_GATEWAY_TOOL_MODE=chatgpt
MCP_GATEWAY_WRITE_MODE=off

# Project root for gateway_project_* tools (e.g. /media/1TB/Python)
# These tools cd into {MCP_GATEWAY_PROJECT_ROOT}/{project} before executing
MCP_GATEWAY_PROJECT_ROOT=
