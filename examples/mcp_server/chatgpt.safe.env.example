# ChatGPT safe mode — private env template
#
# Usage:
#   1. Copy this file to chatgpt.safe.env (already gitignored via .env.* rule)
#   2. Fill in your values
#   3. Run preflight: python3 scripts/mcp_chatgpt_runtime_preflight.py
#   4. Start MCP: set -a && source chatgpt.safe.env && python3 examples/mcp_server/server.py
#
# NEVER commit the real env file with actual tokens or URLs.
# NEVER use master key as MCP runtime credential.

# Gateway connection
GATEWAY_URL=<gateway-url>
GATEWAY_AGENT_TOKEN=<agent-token>

# MCP tool mode
MCP_GATEWAY_TOOL_MODE=chatgpt
MCP_CHATGPT_SAFE_MODE=true

# MCP access profile
MCP_ACCESS_PROFILE=chatgpt_safe

# Project root (optional — for project_* tools)
# MCP_GATEWAY_PROJECT_ROOT=<project-root-path>
