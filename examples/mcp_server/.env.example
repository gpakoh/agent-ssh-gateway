# Agent SSH Gateway MCP server example

GATEWAY_BASE_URL=http://localhost:8085
GATEWAY_API_KEY=
GATEWAY_SESSION_ID=

# Auth mode:
#   oauth — FastMCP-native OAuth 2.1 (default). Only Bearer token accepted.
#   token — no auth (legacy rollback). No mcp_token registration.
MCP_AUTH_MODE=oauth

# Tool visibility: minimal, standard, full, chatgpt
MCP_GATEWAY_TOOL_MODE=standard

# Project root for project-aware tools (e.g. /media/1TB/Python)
# gateway_project_* tools cd into {MCP_GATEWAY_PROJECT_ROOT}/{project}
MCP_GATEWAY_PROJECT_ROOT=

# Write permissions: off, handoff, full
# off is the safest default. handoff allows writing only .ai-bridge/current-plan.md.
MCP_GATEWAY_WRITE_MODE=off

# Safety defaults
MCP_GATEWAY_COMMAND_TIMEOUT=120
MCP_GATEWAY_JOB_TIMEOUT=180
