# agent-ssh-gateway connection
GATEWAY_BASE_URL=http://localhost:8085
GATEWAY_API_KEY=
GATEWAY_SESSION_ID=

# OpenAI / RLM
OPENAI_API_KEY=
RLM_MODEL=gpt-5-nano
RLM_ENVIRONMENT=local
RLM_LOG_DIR=./logs

# RLM subagents (disabled by default, set to 1 to enable)
RLM_ENABLE_SUBAGENTS=0

# RLM safety limits
RLM_MAX_DEPTH=1
RLM_MAX_ITERATIONS=8
RLM_MAX_TIMEOUT=180
RLM_MAX_CONCURRENT_SUBCALLS=2
