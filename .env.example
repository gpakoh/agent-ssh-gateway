# ─── Required ────────────────────────────────────────────────────────────────
API_KEY=change-me-to-a-random-64-char-string

# ─── Optional ────────────────────────────────────────────────────────────────
# Database (PostgreSQL) — uncomment to enable persistent sessions
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ssh_gateway
# PERSISTENT_SESSIONS_ENABLED=true

# Encryption key for credentials at rest
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=["https://gateway.example.com"]

# Redis (defaults to redis://redis:6379/0)
REDIS_URL=redis://redis:6379/0
REDIS_JOB_QUEUE_ENABLED=false

# SSH defaults
SSH_DEFAULT_PORT=22
SSH_DEFAULT_TIMEOUT=120

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Auth
API_AUTH_ENABLED=true
ALLOWED_CLIENT_CIDRS=127.0.0.1/32,::1/128,10.0.0.0/8
TRUSTED_PROXY_CIDRS=127.0.0.1/32,10.0.0.0/8

# Agent token
AGENT_TOKEN=
AGENT_TOKEN_TTL=3600
