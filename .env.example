# Web SSH Gateway example environment
# Copy this file to .env and fill real values locally.
# Do not commit .env with real secrets.

# Server
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8085

# API security
# Production should keep authentication enabled.
API_AUTH_ENABLED=true

# Command policy mode:
# off     - disabled
# audit   - log decisions but do not block commands
# enforce - block commands that do not match the selected profile
COMMAND_POLICY_MODE=audit

# Command policy profile:
# default  - deny obviously dangerous root commands
# readonly - allow only read-only inspection commands
# ops      - allow read-only commands plus limited service/docker operations
COMMAND_POLICY_PROFILE=default
API_KEY=change-me-generate-long-random-api-key
AGENT_TOKEN=change-me-generate-long-random-agent-token

# Client/network restrictions
# Comma-separated CIDRs. Leave empty for local/dev.
ALLOWED_CLIENT_CIDRS=
TRUSTED_PROXY_CIDRS=

# Target host allowlist — what the gateway can connect to over SSH.
# Prevents SSRF-style usage and internal port scanning through the gateway.
ALLOWED_TARGET_CIDRS=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12

# Target networks always denied, even if ALLOWED_TARGET_CIDRS is broad.
DENIED_TARGET_CIDRS=127.0.0.0/8,::1/128,169.254.0.0/16,0.0.0.0/8,224.0.0.0/4

# CORS
# Comma-separated origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:8085

# SSH private key upload via API
# Disabled by default for security. Prefer external secret storage or ephemeral keys.
SSH_KEY_UPLOAD_ENABLED=false

# SSH host key verification
SSH_STRICT_HOST_KEY_CHECKING=true
KNOWN_HOSTS_STORE=file
KNOWN_HOSTS_FILE=/app/ssh/known_hosts

# Server presets
# JSON object with named connection presets. Keep empty by default.
SERVER_DEFAULT_CONFIGS={}

# Session lifecycle
SESSION_TIMEOUT=3600
CLEANUP_INTERVAL=300
MAX_SESSIONS_PER_IP=5
PERSISTENT_SESSIONS_ENABLED=false

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_JOB_QUEUE_ENABLED=true

# Database / persistent storage
DATABASE_URL=sqlite+aiosqlite:////tmp/web-ssh-gateway/sessions.db

# Encryption
# Use a real Fernet key in production.
ENCRYPTION_KEY=change-me-generate-fernet-key

# Rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=60

# Agent token lifecycle
AGENT_TOKEN_TTL=3600

# Event hooks
EVENT_HOOKS_ENABLED=false
EVENT_HOOKS_MAX=100
EVENT_HOOKS_POLL_INTERVAL=1
EVENT_HOOKS_LEASE_TTL=30
EVENT_HOOKS_RETENTION_SENT_DAYS=7
EVENT_HOOKS_RETENTION_DEAD_DAYS=30
EVENT_HOOKS_TIMEOUT_CONNECT=5
EVENT_HOOKS_TIMEOUT_READ=15
EVENT_HOOKS_MAX_ATTEMPTS=3
EVENT_HOOKS_RETRY_BASE_SEC=1
EVENT_HOOKS_RETRY_MAX_SEC=30
EVENT_HOOKS_MAX_OUTPUT_BYTES=65536
EVENT_HOOKS_ALLOW_HTTP=false
